# ── Data mode (client-visible) ───────────────────────────────────────────────
# "mock" (default, zero config) or "finnhub" for live data via the /api proxy.
VITE_QUOTE_PROVIDER=mock
# Quote/news poll interval, ms. (News polls on a ≥60s cadence regardless.)
VITE_REFRESH_MS=15000

# ── Server-side secrets (NO VITE_ prefix → NEVER bundled into the client) ─────
# Used by the /api/* proxy: the Vite dev middleware locally, Vercel functions in
# prod. In production, set these in the Vercel dashboard (Settings → Env Vars),
# NOT in a committed file. Each news source turns on only if its key(s) are set;
# otherwise the proxy falls back to bilingual mock news.
#
#   FINNHUB_API_KEY        — live quotes + English news.  https://finnhub.io/register
#   MARKETAUX_API_TOKEN    — English finance news.        https://www.marketaux.com
#   NAVER_CLIENT_ID/SECRET — Korean news (KO mode).       https://developers.naver.com
FINNHUB_API_KEY=
MARKETAUX_API_TOKEN=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# See DEPLOY.md for the full Vercel setup.
